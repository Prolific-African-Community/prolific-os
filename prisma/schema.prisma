generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum DocumentStatus {
  DRAFT
  GENERATING
  READY_FOR_REVIEW
  APPROVED
  ARCHIVED
}

enum GenerationRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]

  @@map("User")
}

model Project {
  id             String             @id @default(cuid())
  name           String
  description    String?
  status         ProjectStatus      @default(ACTIVE)
  createdById    String
  createdBy      User               @relation(fields: [createdById], references: [id], onDelete: Cascade)
  documents      Document[]
  knowledgeItems ProjectKnowledge[]
  resources      Resource[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([createdById])
  @@index([status])
}

model ProjectKnowledge {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  content   String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([category])
}

model Resource {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentId    String?
  document      Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  filename      String
  mimeType      String
  sizeBytes     Int?
  storageUrl    String?
  extractedText String?

  // Resource Distillation (Ticket 021): a structured "source brief" derived
  // from the extracted text. All nullable so existing rows/flows are unaffected.
  sourceBrief          Json?
  sourceBriefText      String?
  sourceBriefStatus    String?
  sourceBriefModel     String?
  sourceBriefUpdatedAt DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
  @@index([documentId])
}

model Template {
  id              String     @id @default(cuid())
  name            String
  type            String
  description     String?
  structure       String
  generationRules String?
  documents       Document[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([type])
}

model Document {
  id             String          @id @default(cuid())
  projectId      String
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateId     String?
  template       Template?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  title          String
  type           String
  objective      String
  instructions   String?
  status         DocumentStatus  @default(DRAFT)
  outline        String?
  content        String?
  resources      Resource[]
  generationRuns GenerationRun[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([projectId])
  @@index([templateId])
  @@index([status])
  @@index([type])
}

model GenerationRun {
  id           String              @id @default(cuid())
  documentId   String
  document     Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  provider     String
  model        String
  status       GenerationRunStatus @default(PENDING)
  inputSummary String?
  output       String?
  error        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([documentId])
  @@index([status])
}

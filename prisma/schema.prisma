generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum DocumentStatus {
  DRAFT
  GENERATING
  READY_FOR_REVIEW
  APPROVED
  ARCHIVED
}

enum GenerationRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]

  @@map("User")
}

model Project {
  id             String             @id @default(cuid())
  name           String
  description    String?
  status         ProjectStatus      @default(ACTIVE)
  createdById    String
  createdBy      User               @relation(fields: [createdById], references: [id], onDelete: Cascade)
  documents      Document[]
  knowledgeItems ProjectKnowledge[]
  resources      Resource[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([createdById])
  @@index([status])
}

model ProjectKnowledge {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  content   String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([category])
}

model Resource {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentId    String?
  document      Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  filename      String
  mimeType      String
  sizeBytes     Int?
  storageUrl    String?
  extractedText String?

  // Resource Distillation (Ticket 021): a structured "source brief" derived
  // from the extracted text. All nullable so existing rows/flows are unaffected.
  sourceBrief          Json?
  sourceBriefText      String?
  sourceBriefStatus    String?
  sourceBriefModel     String?
  sourceBriefUpdatedAt DateTime?

  visualPlacements DocumentVisualPlacement[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
  @@index([documentId])
}

model Template {
  id              String     @id @default(cuid())
  name            String
  type            String
  description     String?
  structure       String
  generationRules String?
  documents       Document[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([type])
}

model Document {
  id             String          @id @default(cuid())
  projectId      String
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateId     String?
  template       Template?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  title          String
  type           String
  objective      String
  instructions   String?
  status         DocumentStatus  @default(DRAFT)
  outline        String?
  content        String?

  // Document Planning (Ticket 022): structured, section-by-section plan built
  // before final generation. All nullable so existing documents are unaffected.
  documentPlan          Json?
  documentPlanText      String?
  documentPlanStatus    String?
  documentPlanModel     String?
  documentPlanUpdatedAt DateTime?
  // Ticket 025: when the plan was last applied to sections (for out-of-sync detection).
  documentPlanAppliedAt DateTime?
  // Ticket 027: when sections were last assembled into content (for staleness).
  assembledAt           DateTime?

  resources      Resource[]
  generationRuns GenerationRun[]
  sections       DocumentSection[]
  visualPlacements DocumentVisualPlacement[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([projectId])
  @@index([templateId])
  @@index([status])
  @@index([type])
}

// Section-based generation (Ticket 023): each planned section is stored and
// generated independently, then assembled into Document.content.
model DocumentSection {
  id            String    @id @default(cuid())
  documentId    String
  document      Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  planSectionId String?
  orderIndex    Int

  title         String
  level         Int       @default(2)
  purpose       String?
  targetWords   Int?

  sourceBriefs  Json?
  keyFacts      Json?
  keyFigures    Json?
  tables        Json?
  risks         Json?
  assumptions   Json?
  openQuestions Json?

  content       String?
  status        String    @default("PLANNED")
  model         String?
  generatedAt   DateTime?
  editedAt      DateTime?

  // Ticket 026: targeted rewrite memory/tracking (additive, nullable).
  lastRewriteInstruction String?
  rewriteCount           Int       @default(0)
  rewrittenAt            DateTime?

  // Ticket 027: review status + locking (additive).
  reviewStatus  String    @default("DRAFT")
  isLocked      Boolean   @default(false)
  lockedAt      DateTime?
  reviewedAt    DateTime?
  approvedAt    DateTime?

  visualPlacements DocumentVisualPlacement[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([documentId])
  @@index([documentId, orderIndex])
}

model GenerationRun {
  id           String              @id @default(cuid())
  documentId   String
  document     Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  provider     String
  model        String
  status       GenerationRunStatus @default(PENDING)
  inputSummary String?
  output       String?
  error        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([documentId])
  @@index([status])
}

// Visual asset placement (image resources inserted into rendered documents).
model DocumentVisualPlacement {
  id         String   @id @default(cuid())

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  sectionId  String?
  section    DocumentSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  target     String  @default("section")
  role       String  @default("illustration")
  position   String  @default("after_heading")
  size       String  @default("medium")

  caption    String?
  altText    String?
  confidence String?
  reason     String?

  isEnabled   Boolean @default(true)
  isSuggested Boolean @default(true)
  isApproved  Boolean @default(false)

  orderIndex Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentId])
  @@index([resourceId])
  @@index([sectionId])
}
